# Backend Environment Variables
# Copy this file to .env (for development) or set these variables in your production environment

# Port to run the server on
PORT=5000

# MongoDB connection string
# Replace with your actual MongoDB connection string for development or production
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Frontend URL for CORS (comma-separated for multiple origins if needed)
# Development: http://localhost:5173
# Production: https://your-production-domain.com
CORS_ORIGINS=http://localhost:5173